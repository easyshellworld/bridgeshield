# Environment Configuration
NODE_ENV=development
PORT=3000
DATABASE_URL="file:./dev.db"
LOG_LEVEL=info
API_VERSION=v1
EARN_DATA_API_BASE_URL=https://earn.li.fi
LI_FI_API_BASE_URL=https://li.quest
COMPOSER_API_KEY=

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=change-me
DEMO_API_KEY=bridgeshield-demo-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_HIGH=0
CACHE_TTL_MEDIUM=604800000  # 7 days in milliseconds
CACHE_TTL_LOW=259200000     # 3 days in milliseconds
CACHE_TTL_WHITELIST=2592000000  # 30 days in milliseconds
CACHE_TTL_FALLBACK=300000   # 5 minutes in milliseconds

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Risk Scoring
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MEDIUM=31
RISK_SCORE_MAX=100

# C-end Behavior Analytics
BEHAVIOR_THRESHOLD_MEDIUM=30
BEHAVIOR_THRESHOLD_HIGH=60
BEHAVIOR_MAX_CHECKS_24H=20
BEHAVIOR_MAX_CHECKS_7D=80
BEHAVIOR_CHAIN_NOVELTY_MIN_HISTORY=5
BEHAVIOR_SPIKE_RATIO_MEDIUM=8
BEHAVIOR_SPIKE_RATIO_HIGH=25
BEHAVIOR_NEW_USER_HIGH_AMOUNT=100000
BEHAVIOR_DECISION_DRIFT_THRESHOLD=0.4
