# BridgeShield Demo - Netlify Redirects Configuration
# API Proxy: All /api/* requests go to backend server
/api/*  https://bridgeshield.x404.online/api/:splat  200

# SPA Routing: All other requests serve index.html
# NOTE: Netlify automatically serves existing static files (js/css/svg etc.)
# before applying redirect rules, so no explicit asset rules are needed.
#/*      /index.html   200
