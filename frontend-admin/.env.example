# BridgeShield Frontend Admin Environment Configuration
# Copy this file to .env and update values for your environment

# ==============================================
# REQUIRED: Backend API Configuration
# ==============================================

# Backend API Base URL
# - Development (local): http://localhost:3000
# - Docker Compose: http://backend:3000
# - Production: https://api.your-domain.com
# - Leave empty to use Vite proxy (recommended for local dev)
VITE_API_BASE_URL=

# ==============================================
# OPTIONAL: Admin Interface Configuration
# ==============================================

# Default admin credentials (for initial setup only)
# These should be changed after first login for security
# VITE_DEFAULT_ADMIN_USERNAME=admin
# VITE_DEFAULT_ADMIN_PASSWORD=admin123

# ==============================================
# DEPLOYMENT NOTES
# ==============================================
# 1. For Docker builds, environment variables must be set at BUILD TIME
#    because Vite embeds them statically into the compiled bundle
# 2. For development, you can use Vite proxy by leaving VITE_API_BASE_URL empty
#    and configuring proxy in vite.config.ts
# 3. For production, set VITE_API_BASE_URL to your deployed backend URL
# 4. Admin authentication uses JWT tokens after login, no API key needed here